{
  "name": "video-transcript-cli",
  "version": "1.0.0",
  "description": "Simple CLI to fetch and clean YouTube transcripts into text",
  "type": "commonjs",
  "main": "src/cli/index.js",
  "bin": {
    "ytx": "bin/ytx.js"
  },
  "scripts": {
    "start": "node bin/ytx.js",
    "check": "node bin/ytx.js --help",
    "lint": "eslint \"src/**/*.js\" \"bin/**/*.js\"",
    "test": "vitest run --globals",
    "test:watch": "vitest --globals",
    "test:coverage": "vitest run --globals --coverage"
  },
  "keywords": [
    "youtube",
    "transcript",
    "cli",
    "yt-dlp"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "commander": "^14.0.3",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "vitest": "^4.0.18"
  }
}
